# ============================================
# VideoCut — Environment Variables
# ============================================
# Copia questo file come .env.local (frontend) e .env (processor)
# NON committare mai .env.local o .env con valori reali!

# --- Supabase ---
# Dashboard: https://supabase.com/dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# --- Stripe ---
# Dashboard: https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (creati in Stripe Dashboard → Products)
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_ANNUAL=price_...

# --- Google OAuth ---
# Console: https://console.cloud.google.com → APIs & Services → Credentials
# Nota: configurare in Supabase Dashboard → Authentication → Providers → Google
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# --- Apple Sign In ---
# Developer: https://developer.apple.com → Certificates, Identifiers & Profiles
# Nota: configurare in Supabase Dashboard → Authentication → Providers → Apple
APPLE_CLIENT_ID=com.videocut.app
APPLE_SECRET_KEY=...

# --- Redis (Upstash) ---
# Dashboard: https://console.upstash.com
UPSTASH_REDIS_URL=rediss://default:xxx@xxx.upstash.io:6379

# --- Processing Service ---
# URL del Python processing service (Railway)
PROCESSING_SERVICE_URL=https://videocut-processor.up.railway.app
PROCESSING_API_KEY=vc_proc_...your-random-api-key

# --- App Config ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# --- Email (opzionale, per notifiche) ---
# Se usi Resend: https://resend.com/api-keys
RESEND_API_KEY=re_...

# ============================================
# SOLO per il Python Processing Service (.env)
# ============================================

# Supabase (stessi valori di sopra, serve service role key)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Redis (stesso di sopra)
# REDIS_URL=rediss://default:xxx@xxx.upstash.io:6379

# Processing API key (deve matchare con PROCESSING_API_KEY sopra)
# API_KEY=vc_proc_...

# CrisperWhisper model
# WHISPER_MODEL=large-v3
# WHISPER_DEVICE=cpu  # cpu o cuda
# WHISPER_COMPUTE_TYPE=int8  # int8 per CPU, float16 per GPU
