{
  "name": "videocut",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev -w apps/web",
    "build": "npm run build -w apps/web",
    "test": "npm test -w apps/web",
    "format": "prettier --write \"apps/web/src/**/*.{ts,tsx,js,jsx,json,css}\"",
    "format:check": "prettier --check \"apps/web/src/**/*.{ts,tsx,js,jsx,json,css}\""
  }
}
